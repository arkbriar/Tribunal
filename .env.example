# Shared default base URL (used when per-provider URL is not set)
BASE_URL="https://www.packyapi.com"

# Per-provider base URLs (optional — falls back to BASE_URL)
# OPENAI_BASE_URL="https://api.openai.com"
# CLAUDE_BASE_URL="https://api.anthropic.com"
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com"

OPENAI_MODEL=gpt-5.2-low
OPENAI_API_KEY=sk-your-openai-key
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_API_KEY=sk-your-claude-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_KEY=sk-your-gemini-key
